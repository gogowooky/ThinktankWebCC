{
  "name": "thinktank",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,green \"npm run server:dev\" \"node server/wait-for-server.mjs && vite\"",
    "dev:vite": "vite",
    "dev:frontend": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "server:dev": "node --input-type=module -e \"import { readFileSync } from 'fs'; import { config } from 'dotenv'; config({ path: 'server/.env', override: true }); const keyPath = process.env.GOOGLE_SERVICE_ACCOUNT_KEY_FILE; if (keyPath) process.env.GOOGLE_SERVICE_ACCOUNT_KEY = readFileSync(keyPath, 'utf8'); await import('./dist-server/index.js');\"",
    "start": "node dist-server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-virtual": "^3.11.2",
    "@types/multer": "^2.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.474.0",
    "marked": "^18.0.0",
    "marked-highlight": "^2.2.1",
    "monaco-editor": "^0.52.0",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph": "^1.47.6",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  }
}
